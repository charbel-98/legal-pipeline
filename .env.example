ENVIRONMENT=local
LOG_LEVEL=INFO
JSON_LOGS=false

MONGO_ROOT_USERNAME=change-me-root-user
MONGO_ROOT_PASSWORD=change-me-root-password
MONGO_APP_DATABASE=legal_pipeline
MONGO_APP_USERNAME=change-me-app-user
MONGO_APP_PASSWORD=change-me-app-password

MONGODB_URI=mongodb://change-me-app-user:change-me-app-password@localhost:27018/legal_pipeline?authSource=legal_pipeline
MONGODB_DATABASE=legal_pipeline
MONGODB_LANDING_COLLECTION=landing_metadata
MONGODB_PROCESSED_COLLECTION=processed_metadata

MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=change-me-minio-user
MINIO_SECRET_KEY=change-me-minio-password
MINIO_SECURE=false
MINIO_LANDING_BUCKET=landing-zone
MINIO_PROCESSED_BUCKET=processed-zone

SCRAPY_CONCURRENT_REQUESTS=8
SCRAPY_DOWNLOAD_DELAY=0.25
SCRAPY_AUTOTHROTTLE_ENABLED=true
SCRAPY_RETRY_TIMES=3
SCRAPY_REQUEST_TIMEOUT=30
SCRAPY_USER_AGENT=legal-pipeline-bot/0.1
LANDING_RETRY_ATTEMPTS=3

PARTITION_SIZE=monthly
DEFAULT_START_DATE=2024-01-01
DEFAULT_END_DATE=2024-12-31

DAGSTER_HOME=/opt/dagster/dagster_home
